function Create-User {

[cmdletbinding()]

param (

[Parameter(Mandatory=$True)]
[string]$ticket,

[Parameter(Mandatory=$True)]
[string]$firstname,

[Parameter(Mandatory=$True)]
[string]$surname,

[Parameter(Mandatory=$True, HelpMessage="Enter the username")]
[string]$manager,

[Parameter(Mandatory=$True)]
[string]$jobtitle

)

try {
    $dept = Get-ADUser $manager -Properties Department -ErrorAction Stop
}
catch {
    Write-Error "Manager '$manager' not found in Active Directory."
    return
}

Write-Host "---------- Teams Number ----------"
Write-Host " "
$tel = Read-Host "Please enter the last 4 digits of the teams number to assign."
Write-Host " "

Write-Host "---------- Leaving Date ----------"
Write-Host " "
$enddate = [datetime](Read-Host "Leaving date (MM/DD/YYYY) add 1 day extra")
Write-Host " "

$sam = ($firstname + "." + $surname).ToLower()

$date = Get-Date

$Password = (
    ([char[]](33..95) + [char[]](97..126)) + (0..16) |
    Sort-Object {Get-Random}
)[0..16] -join '' | ConvertTo-SecureString -AsPlainText -Force

$newuser = @{

    DisplayName = "$firstname $surname"
    Name = "$firstname $surname"
    SamAccountName = $sam
    GivenName = $firstname
    Surname = $surname
    Company = "UK Finance"
    Department = $dept.Department
    Manager = $manager
    Path = "OU=,OU=Managed Users,DC=,DC=,DC="
    Title = $jobtitle
    OfficePhone = " $tel"
    Description = "Account created on $date by $env:USERNAME (T# $ticket)"
    UserPrincipalName = "$sam@domain"
    EmailAddress = "$sam@domain"
    Enabled = $true
    AccountPassword = $Password

}

New-ADUser @newuser

Start-Sleep -Seconds 1

if ($jobtitle -like "*Intern*") {

    Set-ADAccountExpiration -Identity $sam -DateTime $enddate

    Add-ADGroupMember -Identity "License - Microsoft 365 E5 No Teams" -Members $sam

    set-aduser $sam -clear telephonenumber
}

else {

    Set-ADUser $sam -Add @{
        ProxyAddresses = @(
            "SMTP:$sam@domain"
            "SIP:$sam@domain"
        )
    }

    Set-ADAccountExpiration -Identity $sam -DateTime $enddate

    Add-ADGroupMember -Identity "License - Microsoft 365 E5 and Teams Pay As You Go Calling Plan" -Members $sam
}

$groups = @(
"License - Microsoft Entra Private Access",
"sec-EPA-Intranet",
"sec-CP-DellCommandUpdate",
"sec-CP-ZoomWorkSpace",
"user-SPO-ukf-General",
"Smartway2 Users",
"Intune-users",
"Zoom Outlook Users",
"Zoom Meeting Organisers",
"Exclaimer_AD_All_Staff"
)

foreach ($group in $groups) {
    Add-ADGroupMember -Identity $group -Members $sam
}

Start-Sleep -Seconds 1

Invoke-Command -ComputerName core-aadc-01 -ScriptBlock {
    Start-ADSyncSyncCycle -PolicyType Delta
}

}
